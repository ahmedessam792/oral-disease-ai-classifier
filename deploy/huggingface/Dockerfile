# Hugging Face Docker Space build for the Arcus backend.
#
# This is not the same file as apps/api/Dockerfile. That image expects the
# model to be mounted read-only at runtime (docker-compose's `volumes:`) and
# deliberately never COPYs model/ in. Spaces do not support runtime volume
# mounts — the model has to be part of what gets built, so this Dockerfile
# adds one extra step: COPY model ./model. Everything else is identical.
#
# Build context: this directory, after running
#   scripts/sync-huggingface-space.sh   (or .ps1 on Windows)
# from the repo root, which populates app/, requirements*.txt, and
# model/class_config.json here from the single source of truth in apps/api
# and model/. Those generated files are gitignored — this Dockerfile is the
# only tracked file that assumes their shape.
#
# The trained .keras weight is added directly into this Space's own git
# history (see README.md) — never generated by the sync script, never part
# of the GitHub repository.

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    TF_CPP_MIN_LOG_LEVEL=2

WORKDIR /app

COPY requirements.txt requirements-tf.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Real-model inference. tensorflow-cpu is the same runtime without the CUDA
# payload (~1 GB smaller) — this image only ever runs CPU inference.
# keras is pinned to the version the model was saved with (3.13.2).
RUN pip install --no-cache-dir "tensorflow-cpu==2.21.0" "keras==3.13.2"

# Create the user BEFORE copying anything owned by it — COPY --chown avoids
# the recursive chown that used to duplicate the ~350 MB model into a second
# image layer (chown -R touches every byte it recurses over, and Docker's
# copy-on-write stores that as new layer content, not a metadata-only change).
RUN useradd --create-home appuser

COPY --chown=appuser:appuser app ./app

# The model is part of this Space's own repository (Option A — see
# README.md for why), so it is baked into the image at build time.
COPY --chown=appuser:appuser model ./model

USER appuser

ENV MODEL_DIR=/app/model \
    APP_ENV=production \
    MODEL_MODE=auto \
    API_PORT=7860

# Hugging Face Docker Spaces require the container to listen on 7860.
EXPOSE 7860

# Model loading takes ~10-20s on a cold container; give it room before the
# first health probe counts against us.
HEALTHCHECK --interval=30s --timeout=5s --start-period=90s --retries=3 \
  CMD python -c "import os,urllib.request;urllib.request.urlopen('http://127.0.0.1:'+os.environ.get('API_PORT','7860')+'/health')" || exit 1

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${API_PORT:-7860}"]
