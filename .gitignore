# --- Secrets & environment ---
.env
.env.*
!.env.example

# --- Model artifacts & datasets (placed manually, never committed) ---
# The 350 MB .keras weights and the held-out sample images stay out of git.
# class_config.json is the exception: it is a few hundred bytes of plain config
# (class names, input size, pixel range) and the app + tests need it to resolve
# labels without the weights.
model/*
!model/.gitkeep
!model/README.md
!model/class_config.json
!model/metadata.example.json
!model/labels.example.json
datasets/
data/
uploads/
*.keras
*.h5
*.pt
*.pth
*.onnx
saved_model/

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

# --- Node / Next.js ---
node_modules/
.next/
out/
next-env.d.ts
*.tsbuildinfo

# --- Playwright ---
e2e/test-results/
e2e/playwright-report/
e2e/blob-report/
e2e/.playwright/

# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# --- Hugging Face Space (deploy/huggingface/) ---
# Generated by scripts/sync-huggingface-space.sh (or .ps1) from apps/api and
# model/class_config.json. Regenerate before every deploy; never hand-edit or
# commit these copies. Only the Dockerfile, the Space README, and the
# .gitattributes template are tracked here.
deploy/huggingface/app/
deploy/huggingface/requirements.txt
deploy/huggingface/requirements-tf.txt
deploy/huggingface/model/

# --- Google Cloud Run (deploy/cloud-run/) ---
# Generated by scripts/sync-cloud-run.sh (or .ps1) from apps/api and
# model/class_config.json. Regenerate before every local build; never
# hand-edit or commit these copies. Only the Dockerfile and the README are
# tracked here.
deploy/cloud-run/app/
deploy/cloud-run/requirements.txt
deploy/cloud-run/requirements-tf.txt
deploy/cloud-run/model/

# --- Logs & temp ---
*.log
tmp/
temp/
