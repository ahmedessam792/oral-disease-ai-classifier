# --- Secrets & environment ---
.env
.env.*
!.env.example

# --- Model artifacts & datasets (placed manually, never committed) ---
# The 350 MB .keras weights and the held-out sample images stay out of git.
# class_config.json is the exception: it is a few hundred bytes of plain config
# (class names, input size, pixel range) and the app + tests need it to resolve
# labels without the weights.
model/*
!model/.gitkeep
!model/README.md
!model/class_config.json
!model/metadata.example.json
!model/labels.example.json
datasets/
data/
uploads/
*.keras
*.h5
*.pt
*.pth
*.onnx
saved_model/

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

# --- Node / Next.js ---
node_modules/
.next/
out/
next-env.d.ts
*.tsbuildinfo

# --- Playwright ---
.playwright-mcp/
e2e/test-results/
e2e/playwright-report/
e2e/blob-report/
e2e/.playwright/

# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# --- Local agent / design tooling (kept on disk, never published) ---
# These are development aids, not part of the application.
.claude/
skills/
CLAUDE.md
PRODUCT.md
DESIGN.md
claude-code-oral-disease-project-prompt.md
docs/PROJECT_PLAN.md
.impeccable/
# Impeccable also installs a duplicate copy for GitHub Copilot; the real CI
# workflow under .github/workflows stays tracked.
.github/skills/
.github/hooks/

# --- Logs & temp ---
*.log
tmp/
temp/
