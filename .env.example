# ==============================================================
# Oral Disease AI Classifier — environment template
# Copy to `.env` (never commit real values).
# Backend reads apps/api/.env or process env; frontend reads
# apps/web/.env.local (NEXT_PUBLIC_* only).
# ==============================================================

# --------- Backend (apps/api) ---------
# development | test | production
APP_ENV=development

# Comma-separated allowlist. NEVER "*" in production.
CORS_ORIGINS=http://localhost:3000

# --------- Model ---------
# real  : serve the trained model; a load failure is reported, never masked
#         by falling back to the mock.
# mock  : development predictor only (refused when APP_ENV=production).
# auto  : real when the model files are present, otherwise mock outside
#         production. This is the default.
MODEL_MODE=auto
MODEL_FRAMEWORK=tensorflow

# Paths are resolved relative to MODEL_DIR — never absolute, so the same
# values work locally, in Docker (/app/model), and on Hugging Face Spaces.
MODEL_DIR=../../model
MODEL_PATH=oral_disease_resnet50v2_deployment.keras
MODEL_CONFIG_PATH=class_config.json

# class_config.json carries no version field, so the deployment supplies one.
MODEL_VERSION=1.0.0

# Legacy metadata.json + labels.json fallback (unused by the real model).
MODEL_METADATA_FILE=metadata.json
MODEL_LABELS_FILE=labels.json

# Upload limits
MAX_UPLOAD_MB=10

# Server
API_HOST=0.0.0.0
API_PORT=8000

# --------- Frontend (apps/web/.env.local) ---------
NEXT_PUBLIC_API_URL=http://localhost:8000
